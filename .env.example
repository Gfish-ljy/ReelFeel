# Database
DATABASE_URL=postgresql://anidiary:anidiary_secret@localhost:5432/anidiary
# 开发环境：PostgreSQL 不可用时自动使用 PGlite（无需 Docker）
AUTO_PGLITE_FALLBACK=true
# 强制仅用 PGlite: USE_PGLITE=true
# PGlite 数据目录: PGLITE_DATA_DIR=./.data/pglite

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MinIO / S3-compatible storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=anidiary
MINIO_PUBLIC_URL=http://localhost:9000/anidiary

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Frontend (Vite)
# 开发时用 Vite 代理，留空或设为 /api/v1 即可
VITE_API_URL=/api/v1
